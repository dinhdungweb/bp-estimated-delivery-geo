{% comment %}
  BP: Estimated Delivery & Geo — App Block (Mirror-Logic Version)
  Consolidated Version: Now uses bp-delivery-embed.js for 100% parity.
{% endcomment %}

{{ 'bp-delivery.css' | asset_url | stylesheet_tag }}

<div id="bp-delivery-block-content" 
     data-shop="{{ shop.permanent_domain }}"
     data-product-id="{{ product.id }}"
     data-product-tags="{{ product.tags | join: ',' }}"
     style="display:none; min-height: 100px; margin: 15px 0;">
  <div class="bp-skeleton" id="bp-delivery-block-content-skeleton" style="width:100%; height:120px; background:#f5f5f5; border-radius:12px; animation: bp-skeleton 1.5s infinite ease-in-out;"></div>
</div>

<script src="{{ 'bp-delivery-embed.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "BP: Estimated Delivery",
  "target": "section",
  "settings": []
}
{% endschema %}
